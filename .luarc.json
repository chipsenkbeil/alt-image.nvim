{
  "$schema": "https://raw.githubusercontent.com/LuaLS/vscode-lua/master/setting/schema.json",
  "runtime": {
    "version": "LuaJIT"
  },
  "workspace": {
    "library": [
      "$VIMRUNTIME",
      "$VIMRUNTIME/lua",
      "lua",
      "${3rd}/busted/library",
      "${3rd}/luassert/library",
      "${3rd}/luv/library"
    ],
    "checkThirdParty": "Disable"
  },
  "format": {
    "enable": false
  },
  "diagnostics": {
    "unusedLocalExclude": ["_*"],
    "disable": [
      "luadoc-miss-see-name",
      "no-unknown"
    ]
  }
}
